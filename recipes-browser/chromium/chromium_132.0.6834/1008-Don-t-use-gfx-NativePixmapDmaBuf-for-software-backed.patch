From b0af1d955c187deb2bbfb438ef90d6c0b9506e51 Mon Sep 17 00:00:00 2001
From: Takuro Ashie <ashie@clear-code.com>
Date: Wed, 26 Nov 2025 08:33:44 +0900
Subject: [PATCH] Don't use gfx::NativePixmapDmaBuf for software backed video
 frames

Upstream-Status: Pending

Signed-off-by: Takuro Ashie <ashie@clear-code.com>
---
 media/video/gpu_memory_buffer_video_frame_pool.cc | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/media/video/gpu_memory_buffer_video_frame_pool.cc b/media/video/gpu_memory_buffer_video_frame_pool.cc
index caa757ac37..d09e4d31bf 100644
--- a/media/video/gpu_memory_buffer_video_frame_pool.cc
+++ b/media/video/gpu_memory_buffer_video_frame_pool.cc
@@ -646,6 +646,10 @@ void GpuMemoryBufferVideoFramePool::PoolImpl::CreateHardwareFrame(
 #endif
 
   bool passthrough = false;
+#if BUILDFLAG(IS_LINUX) || BUILDFLAG(IS_CHROMEOS)
+  if (is_software_backed_video_frame)
+    passthrough = true;
+#endif
 #if BUILDFLAG(IS_MAC)
   if (!IOSurfaceCanSetColorSpace(video_frame->ColorSpace()))
     passthrough = true;
-- 
